{
  "name": "proofpack",
  "private": true,
  "version": "0.1.0",
  "description": "Verifiable, tamper-evident receipt + audit pack system for agent/tool runs",
  "scripts": {
    "dev": "concurrently \"pnpm --filter @proofpack/api dev\" \"pnpm --filter @proofpack/web dev\"",
    "build": "pnpm --filter @proofpack/core build && pnpm --filter @proofpack/cli build && pnpm --filter @proofpack/api build && pnpm --filter @proofpack/web build",
    "check": "tsc --build && eslint . && prettier --check .",
    "format": "prettier --write .",
    "semver:check": "node ./scripts/check-semver-policy.mjs",
    "test": "vitest run",
    "e2e": "env -u NO_COLOR playwright test",
    "ci": "pnpm semver:check && pnpm check && pnpm test && pnpm build && pnpm e2e",
    "release:check": "pnpm run ci && pnpm verify -- ./examples/sample_runs/latest.proofpack",
    "sbom:generate": "mkdir -p artifacts && pnpm dlx @cyclonedx/cdxgen -r -o ./artifacts/sbom.cdx.json",
    "release:artifacts": "node ./scripts/build-release-artifacts.mjs",
    "release:attest": "node ./scripts/sign-release-artifacts.mjs",
    "release:attest:verify": "node ./scripts/verify-release-attestation.mjs",
    "repro:check": "node ./scripts/check-reproducible-build.mjs",
    "policy:licenses": "node ./scripts/check-license-policy.mjs",
    "policy:deps": "pnpm audit --audit-level=high && pnpm policy:licenses",
    "changeset": "changeset",
    "changelog:status": "changeset status",
    "changelog:version": "changeset version",
    "stress:core": "pnpm --filter @proofpack/core test:stress",
    "demo": "pnpm --filter @proofpack/cli demo",
    "verify": "pnpm --filter @proofpack/cli verify",
    "diff": "pnpm --filter @proofpack/cli diff"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@next/eslint-plugin-next": "^16.1.6",
    "@playwright/test": "^1.50.0",
    "@types/node": "^25.3.3",
    "concurrently": "^9.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  },
  "engines": {
    "node": ">=20"
  }
}
