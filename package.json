{
  "name": "proofpack",
  "private": true,
  "version": "0.1.0",
  "description": "Verifiable, tamper-evident receipt + audit pack system for agent/tool runs",
  "scripts": {
    "dev": "concurrently \"pnpm --filter @proofpack/api dev\" \"pnpm --filter @proofpack/web dev\"",
    "build": "pnpm --filter @proofpack/core build && pnpm --filter @proofpack/cli build && pnpm --filter @proofpack/api build && pnpm --filter @proofpack/web build",
    "check": "tsc --build && eslint . && prettier --check .",
    "format": "prettier --write .",
    "test": "vitest run",
    "e2e": "env -u NO_COLOR playwright test",
    "ci": "pnpm check && pnpm test && pnpm build && pnpm e2e",
    "release:check": "pnpm run ci && pnpm verify -- ./examples/sample_runs/latest.proofpack",
    "demo": "pnpm --filter @proofpack/cli demo",
    "verify": "pnpm --filter @proofpack/cli verify"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^16.1.6",
    "@playwright/test": "^1.50.0",
    "@types/node": "^22.19.12",
    "concurrently": "^9.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  },
  "engines": {
    "node": ">=20"
  }
}
