{
  "name": "@proofpack/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "proofpack": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "demo": "tsc --build && node --enable-source-maps ./dist/commands/demo.js",
    "verify": "tsc --build && node --enable-source-maps ./dist/index.js verify",
    "test": "vitest run"
  },
  "dependencies": {
    "@proofpack/core": "workspace:*",
    "chalk": "^5.4.0",
    "commander": "^13.0.0"
  },
  "devDependencies": {
    "vitest": "^3.0.0"
  }
}
